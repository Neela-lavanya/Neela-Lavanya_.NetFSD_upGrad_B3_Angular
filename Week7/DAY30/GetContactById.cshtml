@model WebApplication1.Models.ContactInfo



<div class="container mt-4">
    <h2>Contact Details</h2>

    @if (Model != null)
    {
        <table class="table table-bordered">
            <tr><th>Id</th><td>@Model.ContactId</td></tr>
            <tr><th>Name</th><td>@Model.FirstName @Model.LastName</td></tr>
            <tr><th>Company</th><td>@Model.CompanyName</td></tr>
            <tr><th>Email</th><td>@Model.EmailId</td></tr>
            <tr><th>Mobile</th><td>@Model.MobileNo</td></tr>
            <tr><th>Designation</th><td>@Model.Designation</td></tr>
        </table>
    }
    else
    {
        <p class="text-danger">Contact Not Found</p>
    }

    <a asp-action="ShowContacts" asp-controller="Contact" class="btn btn-secondary">Back</a>
</div>