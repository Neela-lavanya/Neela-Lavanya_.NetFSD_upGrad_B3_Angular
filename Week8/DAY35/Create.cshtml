@model WebApplication4.Models.ContactInfo

<h2>Create Contact</h2>

<div asp-validation-summary="All" style="color:red"></div>

<form asp-action="Create" method="post">

    <input asp-for="FirstName" placeholder="First Name" />
    <span asp-validation-for="FirstName"></span><br />

    <input asp-for="LastName" placeholder="Last Name" />
    <span asp-validation-for="LastName"></span><br />

    <input asp-for="EmailId" placeholder="Email" />
    <span asp-validation-for="EmailId"></span><br />

    <input asp-for="MobileNo" placeholder="Mobile" />
    <span asp-validation-for="MobileNo"></span><br />

    <input asp-for="Designation" placeholder="Designation" />
    <span asp-validation-for="Designation"></span><br />

    <!-- Company -->
    <select asp-for="CompanyId"
            asp-items="@(new SelectList(ViewBag.Companies, "CompanyId", "CompanyName"))">
        <option value="0">Select Company</option>
    </select>
    <span asp-validation-for="CompanyId"></span><br />

    <!-- Department -->
    <select asp-for="DepartmentId"
            asp-items="@(new SelectList(ViewBag.Departments, "DepartmentId", "DepartmentName"))">
        <option value="">Optional</option>
    </select><br />

    <button type="submit">Save</button>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}